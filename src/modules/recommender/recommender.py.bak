class EmbeddingRecommender:
    """
    Provide recommendations using embedding.
    """
    def __init__(self, embedding: Embedding):
        self.embedding = embedding
        self.emb_d = self.embedding.entity_iri_to_vec
        self.target_vector = None

    def _build_target_vector(self, liked_movie_ids: list[str]):
        """
        Build a target vector for the liked movies:
        look up the embedding vector for each liked movie,
        then average them into one mean vector,
        which will act as the target vector.
        """
        vectors = []
        for qid in liked_movie_ids:
            if qid in self.emb_d:
                vectors.append(self.emb_d[qid])
        with debug_block():
            print(f" The embedding vectors corresponding to the liked movies are\n{vectors}")
        self.target_vector = np.mean(vectors, axis=0)
        return self.target_vector

    def recommend(self, liked_movie_ids: list[str], k: int = 5):
        """
        Return the list of top embedding vectors that's closest to the target vector.
        """
        self._build_target_vector(liked_movie_ids)
        return self.embedding.k_closest_embedding(self.target_vector, k)

class EmbeddingRecommenderDebugger:
    """
    This class is a debug helper for EmbeddingRecommender.
    """
    def __init__(self, emb_r: EmbeddingRecommender):
        self.emb_r = emb_r
